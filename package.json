{
    "name": "@postzen/node",
    "version": "1.0.0",
    "description": "Node.js SDK for the PostZen Public API",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/postzen-dev/postzen-node.git"
    },
    "main": "dist/api.js",
    "types": "dist/api.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "rm -Rf node_modules/ *.js",
        "build": "tsc",
        "prepack": "npm run build",
        "test": "npm run build && node -e \"require('./dist/api.js')\""
    },
    "author": "OpenAPI-Generator Contributors",
    "license": "Unlicense",
    "dependencies": {
        "bluebird": "^3.7.2",
        "request": "^2.88.2"
    },
    "devDependencies": {
        "@types/bluebird": "^3.5.33",
        "@types/node": "^12",
        "@types/request": "^2.48.8",
        "typescript": "^4.0 || ^5.0"
    }
}
